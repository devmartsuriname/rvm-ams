# RVM-AMS Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# For VPS deployment:
#   1. Copy this file to .env on your VPS
#   2. Fill in the values for your Supabase project
#   3. Ensure .env is in .gitignore (it should already be)

# Supabase Project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase Publishable (Anon) Key
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → anon / public
# This key is safe to expose in client-side code — it is NOT a secret key.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# Supabase Project Reference ID (optional — used for CLI and admin tools)
# Found in: Supabase Dashboard → Project Settings → General → Reference ID
VITE_SUPABASE_PROJECT_ID="your-project-ref"
